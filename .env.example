NODE_ENV=development

# Contact / volunteer email (nodemailer). Required in production; optional in
# development (the mailer is a no-op outside production).
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
MAIL_TO=

# Newsletter (SendGrid). Optional everywhere — when SENDGRID_API_KEY or
# SENDGRID_LIST_ID is unset the homepage newsletter form is hidden.
SENDGRID_API_KEY=
SENDGRID_LIST_ID=

# Object storage (Railway Bucket, S3-compatible) backing the CMS.
# OPTIONAL everywhere — dev and prod both fall back to the bundled defaults
# when unset, so the site is never broken by a missing/unreachable bucket.
# A bucket is "configured" only when ENDPOINT, ACCESS_KEY, SECRET_KEY and NAME
# are all set; REGION defaults to "auto".
BUCKET_ENDPOINT=
BUCKET_ACCESS_KEY=
BUCKET_SECRET_KEY=
BUCKET_NAME=
BUCKET_REGION=auto

# /admin CMS editor session. OPTIONAL everywhere — when ADMIN_PASSWORD is unset
# the admin area is DISABLED (every /admin route 404s), so dev and a
# prod-without-admin both behave as if the admin does not exist. Set both to
# enable it: ADMIN_PASSWORD is the login password; COOKIE_SECRET signs the
# HMAC session cookie (use a long random value).
ADMIN_PASSWORD=
COOKIE_SECRET=
