NODE_ENV=development

# Contact / volunteer email (nodemailer). Required in production; optional in
# development (the mailer is a no-op outside production).
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
MAIL_TO=

# Newsletter (Mailchimp). Required in production; optional in development.
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=

# Object storage (Railway Bucket, S3-compatible) backing the CMS.
# OPTIONAL everywhere — dev and prod both fall back to the bundled defaults
# when unset, so the site is never broken by a missing/unreachable bucket.
# A bucket is "configured" only when ENDPOINT, ACCESS_KEY, SECRET_KEY and NAME
# are all set; REGION defaults to "auto".
BUCKET_ENDPOINT=
BUCKET_ACCESS_KEY=
BUCKET_SECRET_KEY=
BUCKET_NAME=
BUCKET_REGION=auto
