    "dayjs": "^1.11.11",
    "dedent": "^1.5.3",
    "effect": "4.0.0-beta.60",
    "framer-motion": "^11.2.13",
    "isbot": "^5.1.40",
    "lucide-react": "0.469.0",
    "nanoid": "^5.0.7",
