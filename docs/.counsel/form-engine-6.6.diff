-
-const oracleIssues = issuesOf(oracle);
-const engineIssues = issuesOf(
-  engineCodec as Schema.Codec<unknown, unknown, never, never>,
-);
-
-/** Render each issue's key to its locale string (the alias-tolerant comparison). */
